{
  "id": "after_start",
  "name": "After Start Checklist",
  "items": [
    {
      "label": "Anti Ice",
      "challenge": "anti_ice.ogg",
      "fo_only_response": true,
      "validations": [
        {
          "when": {
            "store": { "path": "takeoff.antiIce", "equals": "off" }
          },
          "copilot_response": "off.ogg",
          "checks": [
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_ENG1_BT)", "expected": 0 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_ENG2_BT)", "expected": 0 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_ENG3_BT)", "expected": 0 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_WING_BT)", "expected": 0 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_TAIL_BT)", "expected": 0 },
            { "type": "simvar", "var": "(L:MD11_OPT_AUTO_AICE)", "expected": 0 }
          ]
        },
        {
          "when": {
            "store": { "path": "takeoff.antiIce", "equals": "oneng" }
          },
          "copilot_response": "engineai.ogg",
          "checks": [
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_ENG1_BT)", "expected": 1 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_ENG2_BT)", "expected": 1 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_ENG3_BT)", "expected": 1 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_WING_BT)", "expected": 0 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_TAIL_BT)", "expected": 0 },
            { "type": "simvar", "var": "(L:MD11_OPT_AUTO_AICE)", "expected": 0 }
          ]
        },
        {
          "when": {
            "store": { "path": "takeoff.antiIce", "equals": "onengfoil" }
          },
          "copilot_response": "enginefoilai.ogg",
          "checks": [
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_ENG1_BT)", "expected": 1 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_ENG2_BT)", "expected": 1 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_ENG3_BT)", "expected": 1 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_WING_BT)", "expected": 1 },
            { "type": "simvar", "var": "(L:MD11_OVHD_AICE_TAIL_BT)", "expected": 1 },
            { "type": "simvar", "var": "(L:MD11_OPT_AUTO_AICE)", "expected": 0 }
          ]
        },
        {
          "when": { "always": true },
          "copilot_response": "auto.ogg",
          "checks": [{ "type": "simvar", "var": "(L:MD11_OPT_AUTO_AICE)", "expected": 1 }]
        }
      ]
    },
    {
      "challenge": "air_panel.ogg",
      "label": "Air Panel",
      "copilot_response": "auto.ogg",
      "fo_only_response": true
    },
    {
      "challenge": "apu.ogg",
      "label": "APU",
      "copilot_response": "off.ogg",
      "fo_only_response": true
    },
    {
      "challenge": "hyd_panel.ogg",
      "label": "Hydraulics Panel",
      "fo_only_response": true,
      "copilot_response": "auto.ogg"
    },
    {
      "challenge": "ground_pins.ogg",
      "response": ["removed", "set and checked"],
      "label": "Ground equipment and gear pins"
    },
    {
      "challenge": "cabin_report.ogg",
      "response": ["received", "set and checked"],
      "label": "Cabin report",
      "cargo_skip": true
    }
  ],
  "completion": "after_start_checklist_completed.ogg"
}
