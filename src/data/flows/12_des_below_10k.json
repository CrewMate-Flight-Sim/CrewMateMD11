{
  "id": "desc_ten_thousand_flow",
  "name": "Below 10k/FL100",
  "sound_end": "cabin_landing.ogg",
  "steps": [
    {
      "label": "Lights on",
      "read": "(L:md11_ovhd_lts_ldg_l_sw)",
      "on": "90258 (>L:CEVENT)",
      "expect": 2,
      "skip_delay": true,
      "repeat_on": true
    },
    {
      "label": "Lights on",
      "read": "(L:md11_ovhd_lts_ldg_r_sw)",
      "on": "90260 (>L:CEVENT)",
      "expect": 2,
      "repeat_on": true
    },
    {
      "label": "Lights on",
      "read": "(L:MD11_OVHD_LTS_NOSE_SW)",
      "on": "90262 (>L:CEVENT)",
      "expect": 2,
      "repeat_on": true
    },
    {
      "label": "RWY Turnoff light on",
      "read": "(L:MD11_OVHD_LTS_RWY_TURNOFF_L_BT)",
      "on": "90263 (>L:CEVENT)",
      "expect": 1,
      "skip_delay": true
    },
    {
      "label": "RWY Turnoff light on",
      "read": "(L:MD11_OVHD_LTS_RWY_TURNOFF_R_BT)",
      "on": "90265 (>L:CEVENT)",
      "expect": 1
    },
    {
      "label": "LOGO LT on",
      "read": "(L:MD11_OVHD_LTS_LOGO_BT)",
      "on": "90269 (>L:CEVENT)",
      "expect": 1,
      "only_if": {
        "conditions": [
          {
            "read": "(E:TIME OF DAY)",
            "one_of": [0, 2, 3]
          }
        ]
      }
    },
    {
      "label": "Engine anti ice 1",
      "read": "(L:MD11_OVHD_AICE_ENG1_BT)",
      "on": "{anti_ice_eng1_cmd}",
      "expect": "{anti_ice_eng1_expect}",
      "skip_delay": true,
      "only_if": { "read": "(L:MD11_OPT_AUTO_AICE)", "one_of": [0] }
    },
    {
      "label": "Engine anti ice 2",
      "read": "(L:MD11_OVHD_AICE_ENG2_BT)",
      "on": "{anti_ice_eng2_cmd}",
      "expect": "{anti_ice_eng2_expect}",
      "skip_delay": true,
      "only_if": { "read": "(L:MD11_OPT_AUTO_AICE)", "one_of": [0] }
    },
    {
      "label": "Engine anti ice 3",
      "read": "(L:MD11_OVHD_AICE_ENG3_BT)",
      "on": "{anti_ice_eng3_cmd}",
      "expect": "{anti_ice_eng3_expect}",
      "only_if": { "read": "(L:MD11_OPT_AUTO_AICE)", "one_of": [0] }
    },
    {
      "label": "Wing anti ice",
      "read": "(L:MD11_OVHD_AICE_WING_BT)",
      "on": "{anti_ice_wing_cmd}",
      "expect": "{anti_ice_wing_expect}",
      "skip_delay": true,
      "only_if": { "read": "(L:MD11_OPT_AUTO_AICE)", "one_of": [0] }
    },
    {
      "label": "Tail anti ice",
      "read": "(L:MD11_OVHD_AICE_TAIL_BT)",
      "on": "{anti_ice_tail_cmd}",
      "expect": "{anti_ice_tail_expect}",
      "only_if": { "read": "(L:MD11_OPT_AUTO_AICE)", "one_of": [0] }
    }
  ]
}
