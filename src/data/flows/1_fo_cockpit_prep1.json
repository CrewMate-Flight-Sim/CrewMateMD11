{
  "id": "fo_cockpit_prep1",
  "name": "FO Cockpit Preparation part 1",
  "steps": [
    {
      "label": "Battery on",
      "read": "(L:md11_ovhd_elec_batt_bt)",
      "on": "1 (>L:md11_ovhd_elec_batt_grd)",
      "expect": 1
    },
    {
      "label": "Battery on",
      "read": "(L:md11_ovhd_elec_batt_bt)",
      "on": "90150 (>L:CEVENT)",
      "expect": 1
    },
    {
      "label": "External power on",
      "read": "(L:md11_ovhd_elec_ext_pwr_bt)",
      "on": "90142 (>L:CEVENT)",
      "only_if": {
        "conditions": [
          {
            "read": "(L:md11_ovhd_elec_ext_pwr_on_lt)",
            "one_of": [0]
          }
        ]
      },
      "expect": 1,
      "skip_delay": true
    },
    {
      "label": "External power on",
      "read": "(L:md11_ovhd_elec_ext_pwr_bt)",
      "on": "90143 (>L:CEVENT)",
