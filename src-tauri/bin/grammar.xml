    <one-of>
      <item>takeoff thrust<tag>out="T/O THRUST";</tag></item>
      <item>takeoff clamp<tag>out="T/O CLAMP";</tag></item>
      <item>climb thrust<tag>out="CLB THRUST";</tag></item>
      <item>max continuous thrust<tag>out="MCT THRUST";</tag></item>
      <item>cruise thrust<tag>out="CRZ THRUST";</tag></item>
      <item>thrust<tag>out="THRUST";</tag></item>
      <item>idle clamp<tag>out="IDLE CLAMP";</tag></item>
      <item>idle<tag>out="IDLE";</tag></item>
      <item>retard<tag>out="RETARD";</tag></item>
      <item>go around thrust<tag>out="GA THRUST";</tag></item>
      <item>windshear<tag>out="WINDSHEAR";</tag></item>
      <item>low speed protection<tag>out="LO SPD PROT";</tag></item>
      <item>high speed protection<tag>out="HI SPD PROT";</tag></item>
    </one-of>
  </rule>


  <!-- ───────────────────────────────────────────────────────────
      Lateral Active Modes
      ─────────────────────────────────────────────────────────── -->
  <rule id="FMA_LATERAL_MODE">
    <one-of>
      <item>nav<tag>out="NAV";</tag></item>
      <item>heading<tag>out="HDG";</tag></item>
      <item>track<tag>out="TRK";</tag></item>
      <item>vor<tag>out="VOR";</tag></item>
      <item>vor course<tag>out="VOR CRS";</tag></item>
      <item>localizer<tag>out="LOC";</tag></item>
      <item>align<tag>out="ALIGN";</tag></item>
      <item>rollout<tag>out="ROLLOUT";</tag></item>
      <item>takeoff<tag>out="TAKEOFF";</tag></item>
    </one-of>
  </rule>


  <!-- ───────────────────────────────────────────────────────────
      Lateral Armed Modes
      ─────────────────────────────────────────────────────────── -->
  <rule id="FMA_LATERAL_ARMED">
    <one-of>
      <item>nav armed<tag>out="NAV ARMED";</tag></item>
      <item>loc armed<tag>out="LOC ARMED";</tag></item>
