<?xml version="1.0" encoding="UTF-8"?>
<grammar
  version="1.0"
  xml:lang="en-US"
  xmlns="http://www.w3.org/2001/06/grammar"
  tag-format="semantics/1.0"
  root="TOPLEVEL"
>
  <!-- ═══════════════════════════════════════════════════════════════════════════
       TOPLEVEL
  ════════════════════════════════════════════════════════════════════════════ -->
  <rule id="TOPLEVEL" scope="public">
    <item repeat="0-1">please</item>
    <one-of>
      <item>
        <ruleref uri="#FO_COMMANDS" />
        <tag>out.ActionRuleId="FO_COMMANDS"; out.CmdId=rules.FO_COMMANDS.pid; out.CmdValue=rules.FO_COMMANDS.cval;</tag>
      </item>
      <item>
        <ruleref uri="#FMA_CALLOUTS" />
        <tag>out.ActionRuleId="FMA_CALLOUTS"; out.CmdId=rules.FMA_CALLOUTS.pid; out.CmdValue=rules.FMA_CALLOUTS.cval;</tag>
      </item>
      <item>
        <ruleref uri="#DISCRETE_COMMANDS" />
        <tag>out.ActionRuleId="DISCRETE_COMMANDS"; out.CmdId=rules.DISCRETE_COMMANDS.pid;</tag>
      </item>
    </one-of>
    <item repeat="0-1">please</item>
  </rule>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       FO_COMMANDS  (parameterized — cval carries the numeric value)
  ════════════════════════════════════════════════════════════════════════════ -->
<rule id="FO_COMMANDS">
    <one-of>
      <!-- Heading -->
      <item>
        <item>set</item>
        <item>heading</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <item repeat="0-1">select</item>
        <tag>out.pid="1"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

<!-- Flight level — digit-by-digit: "flight level two seven zero" → "270" -->
      <item>
        <item>set</item>
        <item>flight level</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <item repeat="0-1">select</item>
        <tag>out.pid="2"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <!-- Flight level — round hundreds: "flight level one hundred" → "100" -->
      <item>
        <item>set</item>
        <item>flight level</item>
        <ruleref uri="#FL_HUNDREDS_VALUE" />
        <item repeat="0-1">select</item>
        <tag>out.pid="2"; out.cval=rules.FL_HUNDREDS_VALUE;</tag>
      </item>

      <!-- Altitude feet -->
      <item>
        <item>set</item>
        <item>altitude</item>
        <ruleref uri="#ALTITUDE_VALUE" />
        <item repeat="0-1">select</item>
        <tag>out.pid="3"; out.cval=rules.ALTITUDE_VALUE;</tag>
      </item>

      <!-- Speed -->
      <item>
        <item>set</item>
        <item>speed</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <item repeat="0-1">select</item>
        <tag>out.pid="4"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <!-- Altimeter — bare "XXX[X] set" -->
      <item>
        <ruleref uri="#ALTIMETER_VALUE" />
        <item>set</item>
        <tag>out.pid="7"; out.cval=rules.ALTIMETER_VALUE;</tag>
      </item>

      <!-- Missed approach altitude — auto -->
      <item>
        <one-of>
          <item>set missed approach altitude</item>
          <item>set missed approach</item>
          <item>missed approach altitude</item>
          <item>missed approach</item>
        </one-of>
        <tag>out.pid="15"; out.cval="AUTO";</tag>
      </item>

      <!-- Missed approach altitude — explicit feet -->
      <item>
        <one-of>
          <item>set missed approach altitude</item>
          <item>set missed approach</item>
          <item>missed approach altitude</item>
          <item>missed approach</item>
        </one-of>
        <ruleref uri="#ALTITUDE_VALUE" />
        <item repeat="0-1">feet</item>
        <tag>out.pid="16"; out.cval=rules.ALTITUDE_VALUE;</tag>
      </item>

      <!-- Missed approach altitude — explicit flight level -->
      <item>
        <one-of>
          <item>set missed approach altitude</item>
          <item>set missed approach</item>
          <item>missed approach altitude</item>
          <item>missed approach</item>
        </one-of>
        <item>flight level</item>
        <ruleref uri="#HDG_SPD_FL_VALUE" />
        <tag>out.pid="17"; out.cval=rules.HDG_SPD_FL_VALUE;</tag>
      </item>

      <!-- minimums — "four hundred fifty [feet]" → "450" -->
      <item>
        <ruleref uri="#MINIMUMS_VALUE" />
        <item repeat="0-1">feet</item>
        <item>set</item>
        <tag>out.pid="18"; out.cval=rules.MINIMUMS_VALUE;</tag>
      </item>
    </one-of>
  </rule>

  <!-- ═══════════════════════════════════════════════════════════
      FMA CALLOUT GRAMMAR  –  MD-11 / 717 VIA Avionics
      Pipe: th | thc | lt | ltc | la | vt | vtc | va | ls | pid
      ═══════════════════════════════════════════════════════════ -->

  <rule id="FMA_CALLOUTS">
    <one-of>

      <!-- ── Config A: [ATS] [Lateral] [Pitch] ── -->
      <item>
        <tag>out.th=""; out.thc=""; out.lt=""; out.ltc=""; out.la="";
            out.vt=""; out.vtc=""; out.va=""; out.ls="";</tag>

        <item repeat="0-1">
          <ruleref uri="#FMA_ATS_COLORED" />
          <tag>out.th=rules.FMA_ATS_COLORED.mode;
              out.thc=rules.FMA_ATS_COLORED.color;</tag>
        </item>

        <item repeat="0-1">
          <ruleref uri="#FMA_LATERAL_COLORED" />
          <tag>out.lt=rules.FMA_LATERAL_COLORED.mode;
              out.ltc=rules.FMA_LATERAL_COLORED.color;</tag>
        </item>
        <item repeat="0-1">
          <ruleref uri="#FMA_LATERAL_ARMED" />
          <tag>out.la=rules.FMA_LATERAL_ARMED;</tag>
        </item>

        <item repeat="0-1">
          <ruleref uri="#FMA_VERTICAL_COLORED" />
          <tag>out.vt=rules.FMA_VERTICAL_COLORED.mode;
              out.vtc=rules.FMA_VERTICAL_COLORED.color;</tag>
        </item>
        <item repeat="0-1">
          <ruleref uri="#FMA_VERTICAL_ARMED" />
          <tag>out.va=rules.FMA_VERTICAL_ARMED;</tag>
        </item>

        <item repeat="0-1">
          <ruleref uri="#FMA_LAND_STATUS" />
          <tag>out.ls=rules.FMA_LAND_STATUS;</tag>
        </item>

        <tag>out.pid="1";
            out.cval=out.th+"|"+out.thc+"|"+out.lt+"|"+out.ltc+"|"+out.la+"|"
                    +out.vt+"|"+out.vtc+"|"+out.va+"|"+out.ls+"|"+out.pid;</tag>
      </item>

      <!-- ── Config B: [Pitch] [Lateral] [ATS] ── -->
      <item>
        <tag>out.th=""; out.thc=""; out.lt=""; out.ltc=""; out.la="";
            out.vt=""; out.vtc=""; out.va=""; out.ls="";</tag>

        <item repeat="0-1">
          <ruleref uri="#FMA_VERTICAL_COLORED" />
          <tag>out.vt=rules.FMA_VERTICAL_COLORED.mode;
              out.vtc=rules.FMA_VERTICAL_COLORED.color;</tag>
        </item>
        <item repeat="0-1">
          <ruleref uri="#FMA_VERTICAL_ARMED" />
          <tag>out.va=rules.FMA_VERTICAL_ARMED;</tag>
        </item>

        <item repeat="0-1">
          <ruleref uri="#FMA_LATERAL_COLORED" />
          <tag>out.lt=rules.FMA_LATERAL_COLORED.mode;
              out.ltc=rules.FMA_LATERAL_COLORED.color;</tag>
        </item>
        <item repeat="0-1">
          <ruleref uri="#FMA_LATERAL_ARMED" />
          <tag>out.la=rules.FMA_LATERAL_ARMED;</tag>
        </item>

        <item repeat="0-1">
          <ruleref uri="#FMA_ATS_COLORED" />
          <tag>out.th=rules.FMA_ATS_COLORED.mode;
              out.thc=rules.FMA_ATS_COLORED.color;</tag>
        </item>

        <item repeat="0-1">
          <ruleref uri="#FMA_LAND_STATUS" />
          <tag>out.ls=rules.FMA_LAND_STATUS;</tag>
        </item>

        <tag>out.pid="2";
            out.cval=out.th+"|"+out.thc+"|"+out.lt+"|"+out.ltc+"|"+out.la+"|"
                    +out.vt+"|"+out.vtc+"|"+out.va+"|"+out.ls+"|"+out.pid;</tag>
      </item>

    </one-of>
  </rule>


  <!-- ───────────────────────────────────────────────────────────
      LAND STATUS  (MD-11 autoland capability annunciation)
      Separate from pitch modes — these reflect what the
      autoland system has certified, not what the AP is doing.
      ─────────────────────────────────────────────────────────── -->
  <rule id="FMA_LAND_STATUS">
    <one-of>
      <item>dual land<tag>out="DUAL LAND";</tag></item>
      <item>single land<tag>out="SINGLE LAND";</tag></item>
      <item>approach only<tag>out="APPR ONLY";</tag></item>
    </one-of>
  </rule>


  <!-- ───────────────────────────────────────────────────────────
      COLOR
      ─────────────────────────────────────────────────────────── -->
  <rule id="FMA_COLOR">
    <one-of>
      <item>green<tag>out="GREEN";</tag></item>
      <item>white<tag>out="WHITE";</tag></item>
      <item>magenta<tag>out="MAGENTA";</tag></item>
    </one-of>
  </rule>


  <!-- ───────────────────────────────────────────────────────────
      COLOR WRAPPERS
      ─────────────────────────────────────────────────────────── -->
<rule id="FMA_ATS_COLORED">
  <item>
    <tag>out.mode=""; out.color="";</tag>
    <ruleref uri="#FMA_ATS_MODE" />
    <tag>out.mode=rules.FMA_ATS_MODE;</tag>
    <item repeat="0-1">
      <ruleref uri="#FMA_COLOR" />
      <tag>out.color=rules.FMA_COLOR;</tag>
    </item>
  </item>
</rule>

<rule id="FMA_LATERAL_COLORED">
  <item>
    <tag>out.mode=""; out.color="";</tag>
    <ruleref uri="#FMA_LATERAL_MODE" />
    <tag>out.mode=rules.FMA_LATERAL_MODE;</tag>
    <item repeat="0-1">
      <ruleref uri="#FMA_COLOR" />
      <tag>out.color=rules.FMA_COLOR;</tag>
    </item>
  </item>
</rule>

<rule id="FMA_VERTICAL_COLORED">
  <item>
    <tag>out.mode=""; out.color="";</tag>
    <ruleref uri="#FMA_VERTICAL_MODE" />
    <tag>out.mode=rules.FMA_VERTICAL_MODE;</tag>
    <item repeat="0-1">
      <ruleref uri="#FMA_COLOR" />
      <tag>out.color=rules.FMA_COLOR;</tag>
    </item>
  </item>
</rule>



